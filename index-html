    .stat-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin-top: 4px;
    }

    /* ── RESPONSIVE ── */
