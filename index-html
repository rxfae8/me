  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink:        #0d0d0d;
      --paper:      #f7f5f0;
      --muted:      #888;
      --accent:     #2a5caa;
      --accent-dim: #d6e1f5;
      --border:     #ddd8d0;
      --sidebar-w:  280px;
      --transition: 0.35s cubic-bezier(.4,0,.2,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--paper);
      color: var(--ink);
      min-height: 100vh;
      display: flex;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      position: fixed;
      top: 0; left: 0;
      width: var(--sidebar-w);
      height: 100vh;
      background: var(--ink);
      color: var(--paper);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 24px 32px;
      z-index: 100;
      overflow-y: auto;
    }

    .avatar-initials {
      width: 110px; height: 110px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--accent);
      color: #fff;
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.5rem;
      font-weight: 600;
      letter-spacing: 2px;
      border: 3px solid rgba(255,255,255,.15);
      margin-bottom: 20px;
      flex-shrink: 0;
    }

    .sidebar-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.45rem;
      font-weight: 600;
      text-align: center;
      letter-spacing: 0.5px;
      line-height: 1.25;
    }

    .contacts-toggle {
      margin: 14px 0 6px;
      background: transparent;
      border: 1px solid rgba(255,255,255,.25);
      color: rgba(255,255,255,.75);
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 1.5px;
      padding: 6px 16px;
      border-radius: 2px;
      cursor: pointer;
      transition: var(--transition);
      text-transform: uppercase;
    }
    .contacts-toggle:hover { border-color: var(--accent); color: #fff; }

    .sidebar-tagline {
      font-size: 0.75rem;
      color: rgba(255,255,255,.45);
      text-align: center;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-bottom: 14px;
    }

    .contacts-panel {
      width: 100%;
      overflow: hidden;
      max-height: 0;
      transition: max-height var(--transition);
    }
    .contacts-panel.open { max-height: 400px; }

    .contact-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 4px;
      text-decoration: none;
      color: rgba(255,255,255,.7);
      font-size: 0.8rem;
      transition: var(--transition);
      margin-bottom: 2px;
      word-break: break-all;
    }
    .contact-link:hover { background: rgba(255,255,255,.07); color: #fff; }
    .contact-link .icon { font-size: 1rem; width: 20px; text-align: center; flex-shrink: 0; }

    .sidebar-bio {
      font-size: 0.76rem;
      color: rgba(255,255,255,.42);
      text-align: center;
      line-height: 1.7;
      margin: 18px 0 24px;
      padding: 0 4px;
    }

    .sidebar-nav { width: 100%; margin-top: auto; }
    .nav-link {
      display: block;
      padding: 10px 16px;
      color: rgba(255,255,255,.5);
      text-decoration: none;
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      border-left: 2px solid transparent;
      transition: var(--transition);
    }
    .nav-link:hover, .nav-link.active { color: #fff; border-left-color: var(--accent); }

    /* ── MAIN ── */
    .main {
      margin-left: var(--sidebar-w);
      flex: 1;
      padding: 64px 56px;
      max-width: calc(100% - var(--sidebar-w));
    }

    .section {
      padding: 60px 0;
      border-bottom: 1px solid var(--border);
    }
    .section:last-child { border-bottom: none; }

    .section-label {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 32px;
    }

    h2.section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.8rem;
      font-weight: 300;
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin-bottom: 28px;
    }

    p { font-size: 0.95rem; line-height: 1.8; color: #333; }

    /* ABOUT */
    .about-intro {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.4rem;
      font-weight: 300;
      font-style: italic;
      line-height: 1.7;
      color: #444;
      border-left: 3px solid var(--accent);
      padding-left: 24px;
      margin: 24px 0 40px;
    }

    .what-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
      margin-top: 32px;
    }
    .what-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 22px 20px;
      transition: var(--transition);
    }
    .what-card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .what-card h4 {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 8px;
    }
    .what-card p { font-size: 0.85rem; color: #555; }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; margin-top: 40px; }

    .sub-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 16px;
    }

    .lang-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.88rem;
    }
    .lang-level {
      font-family: 'DM Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 1.5px;
      color: var(--muted);
      text-transform: uppercase;
    }

    .skill-pills { display: flex; flex-wrap: wrap; gap: 8px; }
    .pill {
      padding: 5px 14px;
      border: 1px solid var(--border);
      border-radius: 100px;
      font-size: 0.78rem;
      color: #444;
      background: #fff;
      transition: var(--transition);
    }
    .pill:hover { border-color: var(--accent); color: var(--accent); }

    /* TIMELINE */
    .timeline { margin-top: 8px; }
    .tl-item {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 24px;
      padding: 28px 0;
      border-bottom: 1px solid var(--border);
      align-items: start;
    }
    .tl-item:last-child { border-bottom: none; }
    .tl-date {
      font-family: 'DM Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 1px;
      color: var(--muted);
      padding-top: 4px;
    }
    .tl-role {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-weight: 600;
    }
    .tl-org {
      font-size: 0.82rem;
      color: var(--accent);
      margin-top: 3px;
      margin-bottom: 10px;
    }
    .tl-bullets { padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .tl-bullets li {
      font-size: 0.84rem;
      color: #555;
      line-height: 1.65;
      padding-left: 14px;
      position: relative;
    }
    .tl-bullets li::before {
      content: '–';
      position: absolute;
      left: 0;
      color: var(--accent);
    }

    /* SKILLS */
    .skills-block { margin-bottom: 28px; }
    .skills-block .sub-title { font-size: 1rem; margin-bottom: 12px; }

    /* CONTACT */
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; margin-top: 32px; }
    .contact-info-row { display: flex; flex-direction: column; gap: 22px; }
    .contact-info-item h4 {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 5px;
    }
    .contact-info-item a, .contact-info-item p {
      font-size: 0.9rem;
      color: var(--ink);
      text-decoration: none;
    }
    .contact-info-item a:hover { color: var(--accent); }

    .contact-form { display: flex; flex-direction: column; gap: 16px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label {
      font-family: 'DM Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
    }
    .form-group input, .form-group textarea {
      padding: 11px 14px;
      border: 1px solid var(--border);
      border-radius: 4px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.88rem;
      background: #fff;
      color: var(--ink);
      transition: var(--transition);
      resize: vertical;
    }
    .form-group input:focus, .form-group textarea:focus {
      outline: none;
      border-color: var(--accent);
    }
    .btn-send {
      padding: 12px 28px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 4px;
      font-family: 'DM Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      cursor: pointer;
      align-self: flex-start;
      transition: var(--transition);
    }
    .btn-send:hover { background: #1e4a8a; }

    /* stat row */
